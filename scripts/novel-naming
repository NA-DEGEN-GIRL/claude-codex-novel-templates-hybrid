#!/usr/bin/env python3
"""Codex wrapper for mcp-novel-naming."""
import sys
import os

def main() -> int:
    server_dir = "/root/novel/mcp-novel-naming"
    if server_dir not in sys.path:
        sys.path.insert(0, server_dir)
    from naming_variant import check_naming_variants

    if len(sys.argv) < 2:
        print("Usage: scripts/novel-naming <novel_dir> [episode_range]", file=sys.stderr)
        print("  episode_range: '1-10' (optional, default: all)", file=sys.stderr)
        return 1

    novel_dir = sys.argv[1]
    episode_range = sys.argv[2] if len(sys.argv) >= 3 else ""
    print(check_naming_variants(novel_dir, episode_range))
    return 0

if __name__ == "__main__":
    raise SystemExit(main())
